{
  "name": "abelma",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:pages": "wrangler pages dev",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply abelma --local",
    "db:migrate:remote": "wrangler d1 migrations apply abelma --remote"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@vue-dnd-kit/core": "1.7.0",
    "better-auth": "^1.5.4",
    "canvas-confetti": "^1.9.4",
    "drizzle-orm": "^0.45.1",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.1.18",
    "vue": "^3.5.27",
    "vue-router": "^5.0.1"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^24.10.9",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.42.0",
    "eslint-plugin-vue": "~10.7.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.27.0",
    "oxlint": "~1.42.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vue-tsc": "^3.2.4",
    "wrangler": "^4.71.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
